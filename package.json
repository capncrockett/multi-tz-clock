{
  "name": "multi-tz-clock",
  "version": "1.0.0",
  "productName": "Multi-TZ Clock",
  "description": "A single analog clock face with multiple color-coded hour hands, one per time zone. At a glance, see relative time differences between cities without scanning multiple dials.",
  "main": "desktop/main.cjs",
  "scripts": {
    "desktop:start": "node scripts/start-electron.cjs",
    "desktop:pack": "node scripts/build-electron.cjs pack",
    "desktop:dist": "node scripts/build-electron.cjs dist",
    "desktop:tauri:dev": "tauri dev",
    "desktop:tauri:build": "tauri build",
    "tauri": "tauri",
    "prepare": "node scripts/install-hooks.cjs",
    "test": "npm run test:all",
    "test:all": "npm run test:node && npm run test:e2e",
    "test:node": "jest --config jest.config.cjs --runInBand",
    "test:unit": "jest --config jest.config.cjs tests/unit --runInBand",
    "test:integration": "jest --config jest.config.cjs tests/integration --runInBand",
    "test:tauri": "cargo test --manifest-path src-tauri\\Cargo.toml",
    "test:dev-host": "jest --config jest.config.cjs tests/unit/serve-static.jest.test.js --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --grep desktop",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "guard:pre-commit": "node scripts/agent-guard.cjs pre-commit",
    "guard:pre-push": "node scripts/agent-guard.cjs pre-push",
    "guard:commit-msg": "node scripts/agent-guard.cjs commit-msg",
    "hooks:install": "node scripts/install-hooks.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/capncrockett/multi-tz-clock.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/capncrockett/multi-tz-clock/issues"
  },
  "homepage": "https://github.com/capncrockett/multi-tz-clock#readme",
  "build": {
    "appId": "com.capnc.multi-tz-clock",
    "productName": "Multi-TZ Clock",
    "asar": true,
    "files": [
      "index.html",
      "assets/**/*",
      "desktop/**/*.cjs",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Multi-TZ Clock"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0"
  },
  "private": true
}
